# ── App ──────────────────────────────────────────────────────────────────────
ENV=development
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Database (Neon) ───────────────────────────────────────────────────────────
# Neon Console → project → Connection Details → Pooled connection string
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Clerk Dashboard → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Clerk Dashboard → API Keys → Advanced → JWKS endpoint
# Format: https://<your-app>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://YOUR_APP.clerk.accounts.dev/.well-known/jwks.json
